<?xml version="1.0" encoding="utf-8"?>
<launch>
  <arg name="pose_topic" default="/vrpn_client_node/NMPC0/pose"/>
  <arg name="odom_topic" default="/odom"/>
  <arg name="odom_frame" default=""/>
  <arg name="child_frame" default="base_footprint"/>
  <arg name="pos_offset_x" default="0.0"/>
  <arg name="pos_offset_y" default="0.0"/>
  <arg name="pos_offset_z" default="0.0"/>
  <arg name="filter_tau" default="0.05"/>

  <node pkg="uav_mpc" type="vrpn_pose_to_odom.py" name="vrpn_pose_to_odometry" output="screen">
    <param name="pose_topic" value="$(arg pose_topic)"/>
    <param name="odom_topic" value="$(arg odom_topic)"/>
    <param name="odom_frame" value="$(arg odom_frame)"/>
    <param name="child_frame" value="$(arg child_frame)"/>
    <param name="pos_offset_x" value="$(arg pos_offset_x)"/>
    <param name="pos_offset_y" value="$(arg pos_offset_y)"/>
    <param name="pos_offset_z" value="$(arg pos_offset_z)"/>
    <param name="filter_tau" value="$(arg filter_tau)"/>
  </node>
</launch>
